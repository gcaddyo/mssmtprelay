# Microsoft Entra app registration
TENANT_ID=your-tenant-id-guid
CLIENT_ID=your-public-client-id-guid

# Runtime data and logging
DATA_DIR=/data
LOG_LEVEL=info

# Local SMTP relay bind address (inside container)
SMTP_BIND_ADDR=0.0.0.0:2525

# TLS certificate settings (mounted from ./certs)
TLS_CERT_FILE=/certs/server.crt
TLS_KEY_FILE=/certs/server.key
TLS_MIN_VERSION=1.2

# Optional SMTPS listener (disabled by default)
ENABLE_SMTPS=false
SMTPS_BIND_ADDR=0.0.0.0:2465

# Optional: allow HTML body parsed from SMTP DATA
ALLOW_HTML=true

# Optional (unsafe): allow SMTP AUTH without STARTTLS.
# Use only in trusted internal networks.
ALLOW_INSECURE_AUTH=false

# Optional explicit config file path
# CONFIG_FILE=/data/config.yaml

# Build-time Go module proxy (for regions where proxy.golang.org is unavailable)
GOPROXY=https://goproxy.cn,direct
GOSUMDB=sum.golang.google.cn

# Optional image metadata for release builds
VERSION=dev
COMMIT=none
BUILD_DATE=unknown
